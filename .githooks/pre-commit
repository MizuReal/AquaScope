#!/bin/sh
set -e

if [ ! -d "hugging-face" ]; then
  exit 0
fi

if command -v python >/dev/null 2>&1; then
  python tools/sync_backend_to_hf.py
elif command -v py >/dev/null 2>&1; then
  py -3 tools/sync_backend_to_hf.py
else
  echo "Python is required to run sync hook." >&2
  exit 1
fi

# hugging-face/ is in .gitignore — deployment is handled by GitHub Actions
