# EAS archive: include only frontend project
*

# Allow frontend directory and its content
!frontend/
!frontend/**

# Exclude frontend generated/heavy/local files
frontend/node_modules/
frontend/.expo/
frontend/.git/
frontend/.env
frontend/.env.*
frontend/android/
frontend/ios/
frontend/dist/
frontend/build/
frontend/.next/
frontend/.cache/

# Exclude nested repo and other workspace folders explicitly
ML-AAW/
backend/
web/
moss_model/
moss_dataset/
docs/
debug_output/
csv files/
schemas/
